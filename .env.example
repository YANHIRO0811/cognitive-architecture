# LLM API 配置 (DeepSeek-V4-Pro)
LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 数据库路径
SQLITE_PATH=./data/cognitive.db
CHROMA_PATH=./data/chroma

# 安全护栏
AMYGDALA_FAST_ENABLED=true
AMYGDALA_SLOW_ENABLED=true

# 海马体
HIPPOCAMPUS_STM_MAX_TOKENS=25000
HIPPOCAMPUS_SUMMARY_COMPRESSION=10

# 突显网络
SALIENCE_TICK_INTERVAL_MS=1000
SALIENCE_PROCESSING_TIMEOUT_MS=30000

# 并行度
MAX_CONCURRENT_REGIONS=3
